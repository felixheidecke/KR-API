{
  "name": "kr-api",
  "version": "4.0.0",
  "private": true,
  "description": "Klickrhein feature API",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "format": "prettier --ignore-path .gitignore --write .",
    "update": "ncu -u",
    "update:dry": "ncu"
  },
  "type": "module",
  "author": "Felix Heidecke",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^8.3.0",
    "@fastify/cors": "^8.2.0",
    "date-fns": "^2.29.3",
    "dotenv": "^16.0.3",
    "fastify": "^4.11.0",
    "jsonwebtoken": "^9.0.0",
    "lodash-es": "^4.17.21",
    "mysql2": "^2.3.3",
    "node-fetch": "^3.3.0",
    "nodemailer": "^6.8.0",
    "php-serialize": "^4.0.2",
    "pino-loki": "^2.0.3",
    "redis": "^4.5.1",
    "slashes": "^3.0.12",
    "slugify": "^1.6.5",
    "textile-js": "^2.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.31.0",
    "nodemon": "^2.0.20",
    "npm-check-updates": "^16.6.2",
    "prettier": "^2.8.1"
  },
  "imports": {
    "#src/*": "./src/*",
    "#env": "./src/env.js",
    "#constants": "./src/constants.js",
    "#config/*": "./src/config/*.config.js",
    "#controller/*": "./src/controller/*.controller.js",
    "#data/*": "./src/data/*.data.js",
    "#helper/*": "./src/helper/*.js",
    "#hooks/*": "./src/hooks/*.hooks.js",
    "#libs/*": "./src/libs/*.js",
    "#model/*": "./src/model/*.model.js",
    "#routes/*": "./src/routes/*.routes.js",
    "#utils/*": "./src/utils/*.utils.js"
  }
}
