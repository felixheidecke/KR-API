{
  "name": "kr-api",
  "version": "2.1.0",
  "private": true,
  "description": "Klickrhein feature API",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "format": "prettier --ignore-path .gitignore --write ."
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "trailingComma": "none",
    "printWidth": 80
  },
  "type": "module",
  "author": "Felix Heidecke",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^7.0.0",
    "dotenv": "^16.0.1",
    "fastify": "^3.29.0",
    "lodash-es": "^4.17.21",
    "mysql2": "^2.3.3",
    "nodemailer": "^6.7.5",
    "redis": "^4.1.0",
    "textile-js": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.16",
    "prettier": "^2.6.2"
  },
  "imports": {
    "#config": "./config.js",
    "#utils": "./utils/utils.js",
    "#libs/*": "./libs/*.js",
    "#hooks/*": "./hooks/*.js",
    "#routes/*": "./routes/*.js"
  }
}
