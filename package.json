{
  "name": "kr-api",
  "version": "2.3.0",
  "private": true,
  "description": "Klickrhein feature API",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "format": "prettier --ignore-path .gitignore --write .",
    "update": "ncu -u",
    "update:dry": "ncu"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "trailingComma": "none",
    "printWidth": 80
  },
  "type": "module",
  "author": "Felix Heidecke",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^7.0.0",
    "date-fns": "^2.28.0",
    "dotenv": "^16.0.1",
    "fastify": "^3.29.0",
    "lodash-es": "^4.17.21",
    "mysql2": "^2.3.3",
    "node-fetch": "^3.2.6",
    "nodemailer": "^6.7.5",
    "opening_hours": "^3.8.0",
    "redis": "^4.1.0",
    "slugify": "^1.6.5",
    "textile-js": "^2.1.1"
  },
  "devDependencies": {
    "eslint": "^8.17.0",
    "nodemon": "^2.0.16",
    "npm-check-updates": "^13.1.2",
    "prettier": "^2.6.2"
  },
  "imports": {
    "#config/*": "./config/*.js",
    "#data/*": "./data/*.js",
    "#hooks/*": "./hooks/*.js",
    "#libs/*": "./libs/*.js",
    "#routes/*": "./routes/*.js",
    "#utils/*": "./utils/*.js"
  }
}
