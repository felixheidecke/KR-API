{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "#src/*": [
        "./*"
      ],
      "#env": [
        "env.js"
      ],
      "#constants": [
        "constants.js"
      ],
      "#config/*": [
        "config/*.config.js"
      ],
      "#controller/*": [
        "controller/*.controller.js"
      ],
      "#data/*": [
        "data/*.data.js"
      ],
      "#helper/*": [
        "helper/*.helper.js"
      ],
      "#hooks/*": [
        "hooks/*.hooks.js"
      ],
      "#libs/*": [
        "libs/*.js"
      ],
      "#model/*": [
        "model/*.model.js"
      ],
      "#routes/*": [
        "routes/*.routes.js"
      ],
      "#utils/*": [
        "utils/*.utils.js"
      ],
    }
  }
}