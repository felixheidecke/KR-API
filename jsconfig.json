{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "#config/*": [
        "config/*.config.js"
      ],
      "#data/*": [
        "model/*.data.js"
      ],
      "#hooks/*": [
        "hooks/*.js"
      ],
      "#libs/*": [
        "libs/*.js"
      ],
      "#utils/*": [
        "utils/*.js"
      ],
      "#controller/*": [
        "controller/*.controller.js"
      ],
      "#routes/*": [
        "routes/*.route.js",
        "routes/*.routes.js",
      ]
    }
  }
}